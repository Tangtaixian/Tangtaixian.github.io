{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
   {
  "version": "0.2.0",
  "configurations": [
    {
        "name": "Launch Edge",
        "request": "launch",
        "type": "msedge",
        "url": "http://localhost:8080",
        "webRoot": "${workspaceFolder}"
    },
    {
        "name": "Launch Chrome",
        "request": "launch",
        "type": "chrome",
        "url": "http://localhost:8080",
        "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Chrome调试本地服务器",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",  // 匹配开发服务器端口
      "webRoot": "${workspaceFolder}/src",  // 项目源码根目录
      "sourceMapPathOverrides": {  // 解决source map路径问题
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ]
}